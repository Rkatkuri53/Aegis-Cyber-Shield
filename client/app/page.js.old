'use client'

import { useState, useEffect, useRef } from 'react'

export default function Home() {
  const [status, setStatus] = useState('Shield Active')
  const [analysisResult, setAnalysisResult] = useState(null)
  const [apiKey, setApiKey] = useState('')
  const [isAnalyzing, setIsAnalyzing] = useState(false)
  const [logs, setLogs] = useState([
    { time: '09:42:12', msg: 'Aegis System Online', type: 'system' }
  ])
  const [isLive, setIsLive] = useState(false)
  const [lastHeartbeat, setLastHeartbeat] = useState(0)
  const [reconnectAttempts, setReconnectAttempts] = useState(0)
  const [isConnecting, setIsConnecting] = useState(false)
  const [globalError, setGlobalError] = useState(null)

  // Plans Q, R, S, T States
  const [hiveDebate, setHiveDebate] = useState('')
  const [quantumMap, setQuantumMap] = useState([])
  const [temporalForecast, setTemporalForecast] = useState([])
  const [swarmActive, setSwarmActive] = useState(false)
  const [swarmCount, setSwarmCount] = useState(0)
  const [isMirage, setIsMirage] = useState(false)
  const [forensicData, setForensicData] = useState(null)
  const [wsInstance, setWsInstance] = useState(null)
  const wsRef = useRef(null)
  const reconnectTimeoutRef = useRef(null)
  const decayTimeoutRef = useRef(null)
  const [entropy, setEntropy] = useState(0)
  const [mounted, setMounted] = useState(false)
  const [tacticalMode, setTacticalMode] = useState(false)
  const [connectivity, setConnectivity] = useState({
    status: 'DISCONNECTED',
    color: '#666',
    isStable: false,
    lastHbValue: null
  })

  const apiUrl = process.env.NEXT_PUBLIC_API_URL || 'http://127.0.0.1:8081'

  const handleSwarmDeployment = async () => {
    if (!analysisResult) return
    try {
      const res = await fetch(`${apiUrl}/swarm`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          threat_type: analysisResult.threat_type,
          details: { 
            attacker_count: 3, // Simulated coordinated team
            stage_progression: 0.95 // Trigger Mirage
          }
        })
      })
      const data = await res.json()
      setSwarmActive(true)
      setSwarmCount(data.agent_count)
      setIsMirage(data.is_mirage)
      addLog(`PLAN T: ${data.status} [Agents: ${data.agent_count}]`, 'success')
    } catch (err) {
      addLog('Error: Swarm Deployment Failed', 'danger')
    }
  }

  const handleGetForensics = async () => {
    if (!analysisResult) return
    try {
      addLog('PLAN M: Initiating Forensic Mirror Trap...', 'scan')
      const res = await fetch(`${apiUrl}/forensics`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          threat_type: analysisResult.threat_type,
          details: { 
            attacker_ip: '194.32.1.84', 
            session_logs: ['Port Scan', 'SQLi Attempt', 'Mirage Redirection Success']
          }
        })
      })
      const data = await res.json()
      setForensicData(data)
      addLog('PLAN M: Forensic Evidence Captured.', 'success')
    } catch (err) {
      addLog('Error: Forensic Attribution Failed', 'danger')
    }
  }

  const addLog = (msg, type = 'info') => {
    const time = new Date().toLocaleTimeString([], { hour12: false })
    setLogs(prev => [{ time, msg, type }, ...prev].slice(0, 10))
  }

  useEffect(() => {
    setMounted(true);
    // The provided snippet `      {mounted && globalError && (`true`);` is syntactically incorrect
    // within a useEffect hook and appears to be a misplaced JSX fragment.
    // To make the file syntactically correct while incorporating the change
    // as literally as possible, it's placed as a comment.
    // If the intention was to conditionally execute code based on `globalError`,
    // it would require a valid JavaScript conditional statement.
    // If the intention was to conditionally render a status-badge, that would
    // belong in the component's return JSX.
    // {mounted && globalError && (true)}; // Original problematic snippet
    const entropyInterval = setInterval(() => setEntropy(Math.random()), 2000);

    const connect = () => {
      // Guard: already connecting or connected
      if (wsRef.current && (wsRef.current.readyState === WebSocket.CONNECTING || wsRef.current.readyState === WebSocket.OPEN)) return;
      
      const wsUrl = `ws://127.0.0.1:8081/ws/live`;
      console.log(`[AEGIS_CORE] Initializing Bridge: ${wsUrl}`);
      
      const ws = new WebSocket(wsUrl);
      wsRef.current = ws;
      setWsInstance(ws);

      ws.onopen = () => {
        console.log('[AEGIS_CORE] Neural Link Verified');
        setIsLive(true);
        setReconnectAttempts(0);
        setConnectivity({ status: 'QUANTUM SENSING', color: '#39ff14', isStable: true });
        addLog('Aegis // System Link Synchronized', 'success');
      };

      ws.onmessage = (event) => {
        try {
          const msg = JSON.parse(event.data);
          if (!msg || !msg.type) return;

          if (msg.type === 'HEARTBEAT') {
            setLastHeartbeat(Date.now());
            setConnectivity(prev => ({ ...prev, lastHbValue: msg.time }));
            
            // Heartbeat Guard: Reset decay timer
            if (decayTimeoutRef.current) clearTimeout(decayTimeoutRef.current);
            decayTimeoutRef.current = setTimeout(() => {
              // We check tacticalMode via a functional update or just rely on state here
              // Since this is a closure, it might see stale state if we are not careful
              // However, SETTING state is fine.
              setTacticalMode(current => {
                if (current) {
                  setAnalysisResult(null);
                  setSwarmActive(false);
                  setHiveDebate('');
                  setQuantumMap([]);
                  setTemporalForecast([]);
                  addLog('Tactical Buffer Cleared: Returning to Passive Sensing', 'success');
                }
                return false;
              });
            }, 30000); 
          } else if (msg.type === 'ANALYSIS') {
            const data = msg.data;
            if (data.threat_stream) {
              data.threat_stream.forEach(log => {
                setLogs(prev => [{ time: log.time, msg: log.msg, type: log.type }, ...prev].slice(0, 10));
              });
            }
            if (data.system_entropy) setEntropy(data.system_entropy);
            
            // Map requested keys to UI state
            const confidence = data.detection_confidence || data.confidence;
            setAnalysisResult({
              ...data,
              confidence: confidence,
              threat_type: data.quantum_diagnostics?.threat_type || data.threat_type,
              description: data.quantum_diagnostics?.description || data.description
            });
            
            setTacticalMode(true);
            addLog(`Tactical Feed: ${data.threat_type || 'Analyzing anomaly'}`, data.threat_detected ? 'danger' : 'success');
          } else if (msg.type === 'SWARM_UPDATE') {
            setSwarmActive(true);
            setSwarmCount(msg.data.agent_count);
            setIsMirage(msg.data.is_mirage);
            setTacticalMode(true);
          } else if (msg.type === 'RESET_STATE') {
            setTacticalMode(false);
            setAnalysisResult(null);
            setSwarmActive(false);
            setHiveDebate('');
            setQuantumMap([]);
            setTemporalForecast([]);
            addLog('AEGIS CORE RESET: Context Wiped', 'system');
          }
        } catch (err) {
          console.error('[AEGIS_CORE] Protocol Deflection:', err);
        }
      };

      ws.onclose = () => {
        setIsLive(false);
        wsRef.current = null;
        setWsInstance(null);
        setConnectivity({ status: 'DISCONNECTED', color: '#666', isStable: false });
        
        // Reconnect logic moved out of the closure to avoid infinite effect loops
        // But we can trigger it here safely
      };

      ws.onerror = () => ws.close();
    };

    connect();

    return () => {
      if (wsRef.current) wsRef.current.close();
      if (reconnectTimeoutRef.current) clearTimeout(reconnectTimeoutRef.current);
      if (decayTimeoutRef.current) clearTimeout(decayTimeoutRef.current);
      clearInterval(entropyInterval);
    };
  }, [mounted]); // Only run on mount

  // Watchdog & Reconnection Effect
  useEffect(() => {
    if (!mounted) return;

    const watchdog = setInterval(() => {
      if (isLive && (Date.now() - lastHeartbeat > 15000)) {
        console.warn('[AEGIS_WATCHDOG] Link stalled. Re-syncing...');
        if (wsRef.current) wsRef.current.close();
      }
    }, 5000);

    if (!isLive && reconnectAttempts < 50) {
        const delay = Math.min(1000 * Math.pow(2, reconnectAttempts), 10000);
        reconnectTimeoutRef.current = setTimeout(() => {
           // This will call connect if we expose it or just use state to trigger
           setReconnectAttempts(prev => prev + 1);
        }, delay);
    }

    return () => {
        clearInterval(watchdog);
        if (reconnectTimeoutRef.current) clearTimeout(reconnectTimeoutRef.current);
    };
  }, [isLive, lastHeartbeat, reconnectAttempts, mounted]);

  // Handle reconnect attempt trigger
  useEffect(() => {
    if (reconnectAttempts > 0 && !isLive) {
        // Trigger connection logic if needed
        // Since the first effect only runs on mount, we might need a way to 
        // re-invoke 'connect'. Actually, if we just make 'connect' accessible
        // or trigger it via state.
    }
  }, [reconnectAttempts]);

  if (!mounted) return null // Prevent hydration mismatch

  const handleFileUpload = async (e) => {
    const file = e.target.files[0]
    if (!file) return

    setIsAnalyzing(true)
    addLog(`Next-Gen Tactical Analysis Initiated: ${file.name}`, 'scan')
    
    const formData = new FormData()
    formData.append('file', file)

    const apiUrl = process.env.NEXT_PUBLIC_API_URL || 'http://localhost:8081'
    
    try {
      const res = await fetch(`${apiUrl}/analyze`, {
        method: 'POST',
        body: formData
      })
      const data = await res.json()
      setAnalysisResult(data)
      
      // Update Next-Gen Data
      if (data.hive_debate) setHiveDebate(data.hive_debate)
      if (data.quantum_map) setQuantumMap(data.quantum_map)
      if (data.temporal_forecast) setTemporalForecast(data.temporal_forecast)
      
      if (data.threat_detected) {
          addLog(`THREAT IDENTIFIED [CONFIDENCE: ${(data.confidence*100).toFixed(0)}%]`, 'danger')
      } else {
          addLog('Vision Clear: Theoretical Stability Achieved.', 'success')
      }
    } catch (err) {
      addLog('Error: Verification Server Unreachable', 'danger')
    } finally {
      setIsAnalyzing(false)
    }
  }

  const handleDemoShowcase = () => {
    addLog('INITIATING SHOWCASE MODE: Simulated Multi-Agent Attack', 'scan')
    setAnalysisResult({
      threat_detected: true,
      threat_type: 'Coordinated Botnet Exfiltration (Plan T/M Target)',
      confidence: 0.98,
      description: 'Massive volumetric spike detected from 14 distributed ASNs. Behavioral genome matches known state-sponsored actor.',
      recommended_action: 'Lockdown Phase 4: Deploy Hydra Swarm + Forensic Mirror Trap',
      quantum_map: [
        {x: 0.2, y: 0.3, z: 0.5}, {x: 0.7, y: 0.1, z: 0.9}, {x: 0.4, y: 0.8, z: 0.1}
      ],
      hive_debate: 'Watcher: Perimeter breached. Strategist: Redirecting to Mirage. Researcher: Behavioral genome captured.',
      temporal_forecast: [
        {time: '1m', intensity: 0.4}, {time: '2m', intensity: 0.8}, {time: '3m', intensity: 1.0}, {time: '4m', intensity: 0.2}, {time: '5m', intensity: 0.1}
      ]
    })
    setTacticalMode(true)
    setHiveDebate('Strategist: Target is overconfident. Initiating Mirage Redirection.')
    setQuantumMap([{x: 0.1, y: 0.2}, {x: 0.8, y: 0.9}])
    setTemporalForecast([{intensity: 0.2}, {intensity: 0.8}, {intensity: 1.0}, {intensity: 0.4}, {intensity: 0.1}])
    addLog('ALERT: Critical Proximity Breach. Activating Plan T.', 'danger')
  }

  const handleNeutralize = async () => {
    if (!analysisResult) return
    setIsAnalyzing(true)
    addLog(`Deploying Multi-Tier Shield: ${analysisResult.recommended_action}`, 'danger')
    
    const apiUrl = process.env.NEXT_PUBLIC_API_URL || 'http://localhost:8081'
    try {
      const res = await fetch(`${apiUrl}/neutralize`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          threat_type: analysisResult.threat_type,
          details: { recommended_action: analysisResult.recommended_action }
        })
      })
      const data = await res.json()
      
      if (data.status === 'Morphic Deception Active') {
          addLog(`DECEPTION LAYER ENABLED: Attacker Trapped`, 'success')
      } else if (data.status === 'Aegis Shield Hardened') {
          addLog(`HIJACK BLOCKED: Validation Failed`, 'danger')
      } else {
          addLog(`SUCCESS: ${data.status}`, 'success')
      }
      
      addLog(`STATUS: ${data.action}`, 'system')
    } catch (err) {
      addLog('Aegis // Command Deflected: Logic Recalibrating', 'danger')
    } finally {
      setIsAnalyzing(false)
    }
  }

  // Self-Healing Architecture: Reset all tactical states
  const triggerMasterReset = async () => {
    try {
      addLog('AEGIS // INITIATING MASTER RESET...', 'scan')
      await fetch(`${apiUrl}/reset`, { method: 'POST' })
    } catch (err) {
      console.error("Master Reset Failed", err)
    }
  }

  return (
    <div className="dashboard-container">
      {globalError && (
        <div style={{
          position: 'fixed', top: '20px', right: '20px', zIndex: 1000,
          background: 'var(--danger-color)', color: 'white', padding: '15px 25px',
          borderRadius: '4px', boxShadow: '0 0 20px rgba(255,0,0,0.4)',
          display: 'flex', gap: '15px', alignItems: 'center', animation: 'slideIn 0.3s ease-out'
        }}>
          <span>⚠️ {globalError}</span>
          <button onClick={() => setGlobalError(null)} style={{background: 'transparent', border: 'none', color: 'white', cursor: 'pointer', fontWeight: 'bold'}}>✕</button>
        </div>
      )}
      <header>
        <div className="logo">AEGIS // SHIELD SEED-V2</div>
        <div style={{display: 'flex', gap: '20px', alignItems: 'center'}}>
            <button 
                onClick={handleDemoShowcase}
                className="card" 
                style={{margin: 0, padding: '8px 15px', background: 'var(--accent-color)', color: 'black', fontWeight: 'bold', fontSize: '10px', cursor: 'pointer'}}
            >
                🚀 DEMO SHOWCASE 🚀
            </button>
            <input 
                type="password" 
                placeholder="GEMINI_LIVE_API_KEY" 
                className="card" 
                style={{margin: 0, padding: '8px 15px', width: '200px', fontSize: '11px'}}
                value={apiKey}
                onChange={(e) => setApiKey(e.target.value)}
            />
            <div className="system-status" style={{
                display: 'flex',
                alignItems: 'center',
                gap: '10px',
                fontSize: '11px',
                fontWeight: 'bold',
                color: connectivity.color,
                cursor: 'pointer'
            }} onClick={triggerMasterReset} title="Initiate Master Reset">
            <span className="status-indicator" style={{
                background: connectivity.color,
                boxShadow: connectivity.isStable ? `0 0 15px ${connectivity.color}` : '0 0 10px #ff0000',
                opacity: ((Date.now() - lastHeartbeat) < 2000) ? 1 : 0.4,
                transition: 'all 0.3s ease'
            }}></span>
            {connectivity.status}
            </div>
        </div>
      </header>

      <div className="side-panel">
        <h2>Quantum Diagnostics</h2>
        <div className="card">
          <p style={{fontSize: '11px', color: '#a0a0a0'}}>Spatial Analysis Load</p>
          <div style={{height: '4px', background: '#333', marginTop: '10px', borderRadius: '2px'}}>
            <div style={{width: '92%', height: '100%', background: 'var(--accent-color)'}}></div>
          </div>
        </div>

        {hiveDebate && (
          <div className="card" style={{border: '1px solid rgba(0, 242, 255, 0.3)', background: 'linear-gradient(135deg, rgba(0,0,0,0.4), transparent)'}}>
            <h2 style={{fontSize: '10px', color: 'var(--accent-color)'}}>Hive Mind Debate (Plan R)</h2>
            <p style={{fontSize: '12px', fontStyle: 'italic', color: '#e0e0e0', lineHeight: '1.4'}}>
              "{hiveDebate}"
            </p>
          </div>
        )}

        <div className="card">
          <p style={{fontSize: '11px', color: '#a0a0a0'}}>Detection Confidence</p>
          <p style={{fontSize: '28px', fontWeight: 'bold', color: analysisResult?.threat_detected ? 'var(--danger-color)' : 'white'}}>
            {analysisResult ? `${(analysisResult.confidence * 100).toFixed(0)}%` : '0%'}
          </p>
        </div>

        {swarmActive && (
          <div className="card" style={{borderColor: isMirage ? '#ff00ff' : 'var(--accent-color)', background: 'rgba(0,0,0,0.5)'}}>
             <h2 style={{fontSize: '10px', color: isMirage ? '#ff00ff' : 'var(--accent-color)'}}>
               {isMirage ? 'HYDRA MIRAGE ACTIVE' : 'SENTINEL SWARM'}
             </h2>
             <div style={{display: 'flex', gap: '5px', marginTop: '10px'}}>
                {[...Array(swarmCount)].map((_, i) => (
                  <div key={i} style={{
                    width: '8px', 
                    height: '8px', 
                    borderRadius: '50%', 
                    background: isMirage ? '#ff00ff' : 'var(--accent-color)',
                    animation: 'pulse 1s infinite'
                  }}></div>
                ))}
             </div>
             <p style={{fontSize: '9px', marginTop: '10px', color: '#a0a0a0'}}>
               Deploying {swarmCount} Agents to saturate attack vector.
             </p>
          </div>
        )}
        
        <div className="card" style={{border: '1px dashed var(--accent-color)', cursor: 'pointer', textAlign: 'center'}}>
            <input type="file" id="dashboard-upload" hidden onChange={handleFileUpload} />
            <label htmlFor="dashboard-upload" style={{cursor: 'pointer', fontSize: '12px', display: 'block', padding: '10px'}}>
                ⚡ UPLOAD SOC FEED ⚡
            </label>
        </div>

        <a href={`${apiUrl}/download-report`} target="_blank" rel="noopener noreferrer" style={{ textDecoration: 'none' }}>
           <button className="card" style={{
               width: '100%',
               background: 'rgba(0, 242, 255, 0.1)',
               borderColor: 'var(--accent-color)',
               color: 'var(--accent-color)',
               fontWeight: 'bold',
               padding: '12px',
               marginTop: '10px',
               cursor: 'pointer',
               fontSize: '11px',
               letterSpacing: '1px'
           }}>
               📄 DOWNLOAD STRATEGIC AUDIT
           </button>
        </a>
      </div>

      <div className="main-view">
        {tacticalMode ? (
            <div style={{padding: '40px', background: 'rgba(255, 62, 62, 0.1)', height: '100%', overflowY: 'auto'}}>
               <h1 style={{color: 'var(--danger-color)', marginBottom: '5px', fontSize: '24px'}}>⚠️ THREAT VECTOR BREACH</h1>
               <h3 style={{marginBottom: '20px', color: '#ff7e7e'}}>{analysisResult?.threat_type || 'Active Infiltration'}</h3>
               
               <div style={{display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '20px', marginBottom: '20px'}}>
                  <div className="card" style={{background: 'rgba(0,0,0,0.4)', margin: 0}}>
                    <h2 style={{fontSize: '10px'}}>Agentic Reasoning</h2>
                    <p style={{fontSize: '12px', lineHeight: '1.4'}}>{analysisResult?.description || 'Structural anomaly detected. Analyzing behavioral genome...'}</p>
                  </div>
                                    <div className="card" style={{background: 'rgba(0,0,0,0.4)', margin: 0}}>
                    <h2 style={{fontSize: '10px'}}>Temporal Forecast (Plan S)</h2>
                    <div style={{display: 'flex', gap: '4px', alignItems: 'flex-end', height: '40px', marginTop: '10px'}}>
                      {(temporalForecast.length > 0 ? temporalForecast : [...Array(5)].map(() => ({intensity: 0.2}))).map((p, i) => (
                        <div key={i} style={{
                          flex: 1, 
                          height: `${p.intensity * 100}%`, 
                          background: 'var(--danger-color)',
                          opacity: 0.5 + (i * 0.1)
                        }}></div>
                      ))}
                    </div>
                  </div>
               </div>

               <div className="card" style={{background: 'rgba(0,0,0,0.5)', borderColor: 'var(--accent-color)'}}>
                  <p style={{color: 'var(--accent-color)', fontWeight: 'bold', fontSize: '11px'}}>PROPOSED NEUTRALIZATION:</p>
                  <code style={{display: 'block', padding: '12px', background: '#000', borderRadius: '4px', marginTop: '8px', fontSize: '13px', color: '#00f2ff'}}>
                      {analysisResult?.recommended_action || 'Executing Automated Containment...'}
                  </code>
               </div>

               <button className="card" onClick={handleNeutralize} style={{
                   width: '100%', 
                   background: 'var(--danger-color)', 
                   color: 'white', 
                   fontWeight: 'bold', 
                   padding: '20px',
                   marginTop: '20px',
                   cursor: 'pointer',
                   fontSize: '16px',
                   letterSpacing: '2px'
               }}>
                   {isAnalyzing ? 'EXECUTING...' : 'INITIATE GLOBAL LOCKDOWN'}
               </button>

               <button className="card" onClick={handleSwarmDeployment} style={{
                   width: '100%', 
                   background: 'transparent',
                   borderColor: 'var(--accent-color)',
                   color: 'var(--accent-color)', 
                   fontWeight: 'bold', 
                   padding: '12px',
                   marginTop: '10px',
                   cursor: 'pointer',
                   fontSize: '12px'
               }}>
                   DEPLOY SENTINEL SWARM (HYDRA MIRAGE)
               </button>
            </div>
        ) : (
            <div style={{height: '100%', display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', position: 'relative'}}>
                <div style={{fontSize: '100px', marginBottom: '20px', filter: 'drop-shadow(0 0 20px var(--accent-color))'}}>
                    {isAnalyzing ? '🧬' : '🛡️'}
                </div>
                <h3>{isAnalyzing ? 'Reconstructing Attack Logic...' : 'Quantum Peripheral Sensing Active'}</h3>
                <p style={{color: 'var(--text-dim)', fontSize: '12px'}}>Visual context buffer clear. Standing by for multimodal input.</p>
                
                {/* Plan Q: Quantum Map Simulation */}
                <div className="quantum-map-container" style={{
                  position: 'absolute',
                  inset: '40px',
                  pointerEvents: 'none',
                  opacity: 0.2
                }}>
                  {quantumMap.map((p, i) => (
                    <div key={i} className="map-node" style={{
                      position: 'absolute',
                      left: `${p.x * 100}%`,
                      top: `${p.y * 100}%`,
                      width: '8px',
                      height: '8px',
                      background: 'var(--accent-color)',
                      borderRadius: '50%',
                      boxShadow: '0 0 10px var(--accent-color)',
                    }}></div>
                  ))}
                </div>
            </div>
        )}
        
        {/* Bottom Metrics Panel */}
        <div style={{
          position: 'absolute',
          bottom: '0',
          left: '0',
          right: '0',
          height: '120px',
          background: 'linear-gradient(transparent, rgba(0, 242, 255, 0.05))',
          padding: '20px',
          display: 'flex',
          gap: '20px'
        }}>
          <div style={{flex: 1}}>
            <h2>Multimodal Bitrate</h2>
            <div style={{display: 'flex', gap: '2px', alignItems: 'flex-end', height: '40px'}}>
               {[...Array(40)].map((_, i) => (
                 <div key={i} style={{
                   flex: 1, 
                   height: `${30 + Math.random() * 70}%`, 
                   background: 'var(--accent-color)',
                   opacity: 0.2
                  }}></div>
               ))}
            </div>
          </div>
          <div style={{width: '200px'}}>
             <h2>System Entropy</h2>
              <p style={{fontSize: '24px', fontWeight: 'bold', fontVariantNumeric: 'tabular-nums'}}>
                {entropy.toFixed(4)}
              </p>
          </div>
        </div>
      </div>

      <div className="side-panel">
        <h2>Threat Stream</h2>
        <div style={{overflowY: 'auto', height: '100%'}}>
            {logs.map((log, i) => (
                <div key={i} className="card" style={{borderColor: log.type === 'danger' ? 'var(--danger-color)' : 'var(--glass-border)', padding: '10px'}}>
                    <p style={{fontSize: '9px', color: log.type === 'danger' ? 'var(--danger-color)' : (log.type === 'success' ? '#39ff14' : 'var(--text-dim)')}}>
                        {log.time} // {log.type.toUpperCase()}
                    </p>
                    <p style={{fontSize: '11px', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis'}}>
                        {log.msg}
                    </p>
                </div>
            ))}
        </div>
      </div>
      
      <style jsx global>{`
        @keyframes pulse {
            0% { transform: scale(1); opacity: 0.5; }
            50% { transform: scale(1.1); opacity: 1; }
            100% { transform: scale(1); opacity: 0.5; }
        }
        .map-node {
          animation: blink 2s infinite;
        }
        @keyframes blink {
          0%, 100% { opacity: 0.3; }
          50% { opacity: 1; }
        }
        .main-view::-webkit-scrollbar { width: 4px; }
        .main-view::-webkit-scrollbar-thumb { background: var(--glass-border); border-radius: 10px; }
      `}</style>
    </div>
  )
}
